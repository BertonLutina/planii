      "ok":            { "$type": "color", "$value": "#0f6e56" },
      "ok-bg":         { "$type": "color", "$value": "#e1f5ee" },
      "blue":          { "$type": "color", "$value": "#185fa5" },
      "blue-bg":       { "$type": "color", "$value": "#eaf2fb" },
      "gold":          { "$type": "color", "$value": "#ba7517" }
    },
    "dark": {
      "bg":            { "$type": "color", "$value": "#1b1a17" },
      "surface":       { "$type": "color", "$value": "#26251f" },
      "surface-2":     { "$type": "color", "$value": "#302e27" },
      "line":          { "$type": "color", "$value": "#3a382f" },
      "line-strong":   { "$type": "color", "$value": "#4a473c" },
      "text":          { "$type": "color", "$value": "#f1efe8" },
      "muted":         { "$type": "color", "$value": "#b4b2a9" },
      "hint":          { "$type": "color", "$value": "#9a988f" },
      "accent":        { "$type": "color", "$value": "#afa9ec" },
      "accent-bg":     { "$type": "color", "$value": "#2b2758" },
      "accent-2":      { "$type": "color", "$value": "#afa9ec" },
      "on-accent":     { "$type": "color", "$value": "#1b1a17" },
      "danger":        { "$type": "color", "$value": "#f09595" },
      "danger-bg":     { "$type": "color", "$value": "#3a1a1a" },
      "warn":          { "$type": "color", "$value": "#efa927" },
      "warn-bg":       { "$type": "color", "$value": "#3a2a10" },
      "ok":            { "$type": "color", "$value": "#5dcaa5" },
      "ok-bg":         { "$type": "color", "$value": "#123027" },
      "blue":          { "$type": "color", "$value": "#85b7eb" },
      "blue-bg":       { "$type": "color", "$value": "#12233a" },
      "gold":          { "$type": "color", "$value": "#ef9f27" }
    }
  },
  "space": {
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "8":  { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "14px" },
    "xl":   { "$type": "dimension", "$value": "18px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "fontFamily": {
    "sans": { "$type": "fontFamily", "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica", "Arial", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "Consolas", "monospace"] }
  },
  "fontSize": {
    "xs":   { "$type": "dimension", "$value": "11px" },
    "sm":   { "$type": "dimension", "$value": "13px" },
    "base": { "$type": "dimension", "$value": "15px" },
    "md":   { "$type": "dimension", "$value": "16px" },
    "lg":   { "$type": "dimension", "$value": "17px" },
    "xl":   { "$type": "dimension", "$value": "22px" },
    "2xl":  { "$type": "dimension", "$value": "26px" },
    "3xl":  { "$type": "dimension", "$value": "31px" }
  },
  "fontWeight": {
    "normal": { "$type": "fontWeight", "$value": 400 },
    "medium": { "$type": "fontWeight", "$value": 600 },
    "bold":   { "$type": "fontWeight", "$value": 700 },
    "black":  { "$type": "fontWeight", "$value": 800 }
  },
  "lineHeight": {
    "tight":   { "$type": "number", "$value": 1.2 },
    "normal":  { "$type": "number", "$value": 1.5 },
    "relaxed": { "$type": "number", "$value": 1.7 }
  },
  "shadow": {
    "sm": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(0,0,0,0.05)" } },
    "md": { "$type": "shadow", "$value": [
      { "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "rgba(0,0,0,0.06)" },
      { "offsetX": "0", "offsetY": "6px", "blur": "20px", "spread": "0", "color": "rgba(0,0,0,0.05)" }
    ] },
    "lg": { "$type": "shadow", "$value": [
      { "offsetX": "0", "offsetY": "8px", "blur": "24px", "spread": "0", "color": "rgba(0,0,0,0.10)" },
      { "offsetX": "0", "offsetY": "2px", "blur": "6px", "spread": "0", "color": "rgba(0,0,0,0.06)" }
    ] }
  },
  "duration": {
    "fast": { "$type": "duration", "$value": "120ms" },
    "base": { "$type": "duration", "$value": "200ms" },
    "slow": { "$type": "duration", "$value": "320ms" }
  },
  "easing": {
    "out":    { "$type": "cubicBezier", "$value": [0.2, 0.8, 0.2, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
  }
}
