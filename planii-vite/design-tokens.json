      "accent-bg":     { "$type": "color", "$value": "#eeedfe" },
      "accent-2":      { "$type": "color", "$value": "#7f77dd" },
      "on-accent":     { "$type": "color", "$value": "#ffffff" },
      "danger":        { "$type": "color", "$value": "#a32d2d" },
