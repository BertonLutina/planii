# Copiez ce fichier en « .env » et adaptez les valeurs.

# Port d'écoute du backend
PORT=4000

# Connexion à votre PostgreSQL (Hostinger). Format :
#   postgres://UTILISATEUR:MOTDEPASSE@HOTE:5432/NOM_BASE
# Exemple local sur le VPS : postgres://planii:motdepasse@localhost:5432/planii
DATABASE_URL=postgres://planii:motdepasse@localhost:5432/planii

# Mettre à "true" si votre PostgreSQL exige une connexion SSL (souvent le cas
# pour une base managée/distante ; inutile si Postgres tourne sur le même VPS).
PGSSL=false

# Secret pour signer les jetons de connexion (JWT).
# Générez une valeur longue et aléatoire :
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=remplacez-par-une-valeur-aleatoire-longue

# URL publique de l'application front (utilisée dans les liens d'invitation).
APP_URL=https://planii.app

# Durée de validité des liens d'invitation (en jours)
INVITE_DAYS=14
